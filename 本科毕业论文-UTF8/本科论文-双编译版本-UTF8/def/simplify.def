\makeatletter
\def\zhdigits#1{%
	\expandafter\@zhdigits#1\relax
}
\def\@zhdigits#1{%
	\ifx#1\relax
		\let\next=\relax
		\else
			\ifcase#1 〇\or 一\or 二\or 三\or 四\or 五\or 六\or 七\or 八\or 九\fi
			\let\next=\@zhdigits
			\fi
		\next
	}
\makeatother
%%%%%% 居中
\def\centend#1{\cent{\mbox{}\hfill#1 \eproof}}
%%%%  居中
\newcommand{\cent}[2][1]
    {\def\centskipstart{\medskip}\def\centskipend{\medskip}
    \ifnum#1=2\def\centskipend{}
        \else\ifnum#1=3\def\centskipstart{}
            \else\ifnum#1=4
                \def\centskipend{}\def\centskipstart{}
                \fi
            \fi
        \fi
    \centskipstart\par\centerline{#2}\centskipend\par}

\newcommand\setcolsep[1][2]   %微调列宽
    {\setlength\arraycolsep{#1pt}}

%%%%%%%%% 无框单元格
\newcommand{\MakeBox}[3][s]
    {\makebox[#2\ccwd][#1]{\let\CJKglue\hfill #3}}
\newcommand{\MB}[3][c]
    {\makebox[#2\ccwd][#1]{#3}}

%%%%%%%% 列表环境
\renewcommand{\labelitemi}{$\bullet$}
\newcommand{\myback}[1][25]{\vspace*{-#1pt}}
\def\myhalfback{\myback[12.5]}


%%%%%%% 问卷调查选项格式
    \newlength\chfour\newlength\chtwo
    \newlength\chthree\newlength\chone
    \setlength\chfour{3.875cm}
    \setlength\chthree{5.167cm}
    \setlength\chtwo{7.75cm}
    \setlength\chone{15.5cm}

\def\mychA{\textup{A}}
\def\mychB{\textup{B}}
\def\mychC{\textup{C}}
\def\mychD{\textup{D}}\def\mychE{\textup{A}}
\def\myyback{-12pt}
\def\my@choice@back{\vspace*{-8pt}}
\newlength\chA\newlength\chB\newlength\chC\newlength\chD \newlength\chtest
\newlength\chAB\newlength\chCD\newlength\chAD\newlength\chBC
\newcommand{\choneintwoft}[2]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
    \mychA.#1&\mychB.#2
    \end{tabular}}
\newcommand{\choneintwosd}[2]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{@{}p{\chone}}
         \mychA.#1\\[\myyback]
         \mychB.#2
    \end{tabular}}
\newcommand{\choneinthreeft}[3]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{3}{@{}p{\chthree}}}
         \mychA.#1&\mychB.#2&\mychC.#3
    \end{tabular}
    }
\newcommand{\choneinthreesd}[3]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
         \mychA.#1&\mychB.#2\\[\myyback]
        \multicolumn{2}{@{}p{\chone}}{\mychC.#3}
    \end{tabular}}
\newcommand{\choneinthreetd}[3]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
        \multicolumn{2}{@{}p{\chone}}{
            \mychA.#1} \\[\myyback]
         \mychB.#2&\mychC.#3
    \end{tabular}}
\newcommand{\choneinthreefh}[3]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{@{}p{\chone}}
         \mychA.#1\\[\myyback]
         \mychB.#2\\[\myyback]
         \mychC.#3
    \end{tabular}}
\newcommand{\choneinfourft}[4]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{4}{@{}p{\chfour}}}
        \mychA.#1&\mychB.#2&\mychC.#3&\mychD.#4
    \end{tabular}}
\newcommand{\choneinfoursd}[4]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
        \mychA.#1&\mychB.#2\\[\myyback]
        \mychC.#3&\mychD.#4
    \end{tabular}}
\newcommand{\choneinfourtd}[4]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
        \mychA.#1&\mychB.#2\\[\myyback]
        \multicolumn{2}{@{}p{\chone}}{\mychC.#3}\\[\myyback]
        \multicolumn{2}{@{}p{\chone}}{\mychD.#4}
    \end{tabular}}
\newcommand{\choneinfourfh}[4]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
        \multicolumn{2}{@{}p{\chone}}{%
            \mychA.#1}\\[\myyback]
        \multicolumn{2}{@{}p{\chone}}{%
            \mychB.#2}\\[\myyback]
        \mychC.#3&\mychD.#4
    \end{tabular}}
\newcommand{\choneinfourff}[4]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
    \par\noindent\quad
    \begin{tabular}{*{2}{@{}p{\chtwo}}}
        \multicolumn{2}{@{}p{\chone}}{%
        \mychA.#1}\\[\myyback]
        \mychB.#2&\mychC.#3\\[\myyback]
        \multicolumn{2}{@{}p{\chone}}{\mychD.#4}
    \end{tabular}}

    \newcommand{\choneinfoursx}[4]{\ifx\mychA\mychE\relax\else\my@choice@back\fi%
        \par\noindent\quad
        \begin{tabular}{@{}p{\chone}}
        \mychA.#1\\[\myyback]
        \mychB.#2\\[\myyback]
        \mychC.#3\\[\myyback]
        \mychD.#4
        \end{tabular}}

    \newcommand{\choice}[4][]
        {
        \settowidth{\chD}{\zihao{-4}\mychD.#1;}
        \settowidth{\chA}{\zihao{-4}\mychA.#2;}
        \settowidth{\chB}{\zihao{-4}\mychB.#3;}
        \settowidth{\chC}{\zihao{-4}\mychC.#4;}
        \settowidth{\chtest}{\zihao{-4}D.;}
        \ifthenelse{\chA>\chB}{\chAB=\chA}{\chAB=\chB}
        \ifthenelse{\chC>\chD}{\chCD=\chC}{\chCD=\chD}
        \ifthenelse{\chB>\chC}{\chBC=\chB}{\chBC=\chC}
        \ifthenelse{\chAB>\chCD}{\chAD=\chAB}{\chAD=\chCD}
\ifthenelse{\chC<\chtest}
    {\ifthenelse{\chAB<\chtwo}{\choneintwoft{#2}{#3}}
            {\choneintwosd{#2}{#3}}}
    {\ifthenelse{\chD=\chtest}
        {
        \ifthenelse{\chAD<\chthree}{\choneinthreeft{#2}{#3}{#4}}
            {
            \ifthenelse{\chAB<\chtwo}
                {\choneinthreesd{#2}{#3}{#4}}
                {\ifthenelse{\chBC<\chtwo}
                    {\choneinthreetd{#2}{#3}{#4}}
                    {\choneinthreefh{#2}{#3}{#4}}
                }
            }
        }
        {
        \ifthenelse{\chAD<\chfour}
            {\choneinfourft{#2}{#3}{#4}{#1}}
            {
            \ifthenelse{\chAD<\chtwo}
                {\choneinfoursd{#2}{#3}{#4}{#1}}
                {
                \ifthenelse{\chAB<\chtwo}
                    {\choneinfourtd{#2}{#3}{#4}{#1}}
                    {\ifthenelse{\chBC<\chtwo}
                    {\choneinfourff{#2}{#3}{#4}{#1}}
                    {
                    \ifthenelse{\chCD<\chtwo}
                        {\choneinfourfh{#2}{#3}{#4}{#1}}
                        {\choneinfoursx{#2}{#3}{#4}{#1}}
                        }
                    }
                }
            }
        }
    }
    }

\def\chf#1#2#3#4{\choice[#4]{#1}{#2}{#3}}
%%%% 调用格式 三个选项 \choice{选项1}{选项2}{选项3}
%%%%          四个选项 \chf{选项1}{选项2}{选项3}{选项4}
%5个选项, 但每个选项都不长, 直接使用表格生成,
    \newcommand{\chfive}[5]{\vspace*{-5pt}\par\noindent\quad
        \begin{tabular}{*{5}{@{}p{3cm}}}
                \mychA.#1&\mychB.#2&\mychC.#3&\mychD.#4&E.#5
        \end{tabular}}

%%%%%% 参考文献上标命令
\makeatletter
\let\chfold\chf
\let\choiceold\choice
\def\chf{\par\vspace*{-3.5pt}\chfold}
\def\choice{\par\vspace*{-3.5pt}\choiceold}

\def\upcite{\@ifnextchar[{\upcitei}{\upciteii}}
\def\upcitei[#1]#2{\textsuperscript{\textsuperscript{\cite[#1]{#2}}}}
\def\upciteii#1{\textsuperscript{\textsuperscript{\cite{#1}}}}
\makeatother
