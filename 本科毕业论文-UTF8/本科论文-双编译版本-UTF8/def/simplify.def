%%%%%%%%%%%% 由于宏包冲突, 将定理环境放置此处
%%%%%%%%% 定理环境
\def\kg{\mbox{}\qquad}
% 应用样式并定义定理环境
\theoremstyle{mytheorem}

\renewcommand{\thefigure}{\thesection-\arabic{figure}}
\renewcommand{\thetable}{\thesection-\arabic{table}}
\setlength{\abovecaptionskip}{4pt}   % 图表标题上方间距
\setlength{\belowcaptionskip}{0pt}   % 图表标题下方间距
\setlength{\intextsep}{8pt}          % 图表环境与正文的总间距
\newtheorem{theo}{\kg 定理}[section] %定理编号带有节前缀
\newtheorem{theorem}[theo]{\kg 定理} % 定理环境，按章节编号
\newtheorem{lemma}[theo]{\kg 引理}   % 引理，与定理同编号
\newtheorem{coro}[theo]{\kg 推论}
\newtheorem{prop}[theo]{\kg 命题}
\newtheorem{propt}[theo]{\kg 性质}
\newtheorem{lem}[theo]{\kg 引理}
\newtheorem{defi}[theo]{\kg 定义}
\newtheorem{exam}[theo]{\kg 例}
\newtheorem{ques}[theo]{\kg 问题}
\newtheorem{exa}{\kg例}[section]
\newtheorem{conj}[theo]{\kg 猜想}
\newtheorem{rema}[theo]{\kg 注}
\numberwithin{equation}{section}
%%%%%%%%%%%% 定理环境结束


