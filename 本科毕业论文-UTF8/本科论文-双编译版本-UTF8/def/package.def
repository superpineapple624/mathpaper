%!Mode:: "TeX:UTF-8"使用UTF8编码
\usepackage{iftex}  % 专门用于检测编译引擎的宏包
\ifXeTeX
  % XeLaTeX配置
  \usepackage{fontspec,fontenc}
  
  \usepackage{xeCJK}
%  \setCJKmainfont[BoldFont=SimHei]{SimSun}
  \setmainfont{Times New Roman}
  \setCJKmainfont[BoldFont=SimHei,ItalicFont=KaiTi]{SimSun}
  %\newcommand{\mycmd}{XeLaTeX命令}
  \else\ifLuaTeX
  % LuaLaTeX配置
    \usepackage{fontspec}
    \usepackage{luatexja-fontspec}
    \setmainjfont{MS Mincho}
  %\newcommand{\mycmd}{LuaLaTeX命令}
    \else
  % PDFLaTeX配置
        \usepackage[T1]{fontenc}
        \usepackage[utf8]{inputenc}
        \usepackage{cjkutf8,lmodern,times}
        \usepackage{ccmap}       %pdf中文不乱码
        \def\CJK@bold{1}   % 强制开启中文粗体
        \def\CJK@family{song}
        \usepackage{lmodern}    %花括号不间断
    %\usepackage{newtxtext,newtxmath}  % PDFLaTeX下的字体
  %\newcommand{\mycmd}{PDFLaTeX命令}
    \fi
\fi

% 所有引擎通用的宏包
\usepackage{hyperref}
\usepackage[left=3cm,right=2.5cm,top=3cm,bottom=2.5cm]{geometry}%页边距
\usepackage{setspace} % 行间距
\usepackage{fancyhdr} % 页眉页脚
\usepackage{wrapfig}  % 文字环绕图片
\usepackage{indentfirst}% 首行缩进

% 图片与浮动体
