%页边距
\oddsidemargin=0pt
\evensidemargin=0pt
\setlength{\parindent}{2\ccwd} %设置段首缩进量

%公式与正文间的额外间距
\abovedisplayshortskip=0pt
\belowdisplayshortskip=0pt
\abovedisplayskip=0pt
\belowdisplayskip=0pt
%设置列表环境各种间距
\setenumerate{itemsep=-2pt,partopsep=0pt,parsep=\parskip,topsep=0pt}
\setitemize{itemsep=-2pt,partopsep=0pt,parsep=\parskip,topsep=0pt}
\setdescription{itemsep=-2pt,partopsep=0pt,parsep=\parskip,topsep=0pt}
%%%% 图表说明与正文的间距
\setlength{\abovecaptionskip}{0.cm}
\setlength{\belowcaptionskip}{-0.cm}

\renewcommand\arraystretch{1}

%%%% 字体
\newcommand{\song}{\CJKfamily{song}} %宋体
\newcommand{\kai}{\CJKfamily{kai}} %楷体
\newcommand{\hei}{\CJKfamily{hei}} %黑体
%\newcommand{\fangsong}{\CJKfamily{fs}} %仿宋
\newcommand{\li}{\CJKfamily{li}} %隶书
\newcommand{\you}{\CJKfamily{you}} %幼圆

%%%% 重定义标准大小
\makeatletter
\renewcommand{\normalsize}{%
\@setfontsize\normalsize\@xpt\@xiipt
\abovedisplayskip 4\p@ \@plus2\p@ \@minus5\p@
\abovedisplayshortskip \z@ \@plus 3\p@
\belowdisplayshortskip 4\p@ \@plus 3\p@ \@minus3\p@
\belowdisplayskip \abovedisplayskip
\let\@listi\@listI}

%\setlength{\arraycolsep}{2pt}
%一级标题格式
\renewcommand\section{%
\@startsection{section}{0}{-2\ccwd}{10pt}{8pt}%
{\!\zihao{-3}\song\textbf}%
}
%\titleformat{\section}
%  {\zihao{-3}\song\bfseries}
%  {\thesection}{.75em}{}
%  [\vspace*{-13pt}]
%titleformat{command}[shape]{format}{label}{sep}{before}[after]

% 二级标题格式
\renewcommand\subsection{%
\@startsection{subsection}{1}{-4pt}{5pt}{5pt}%
{\song\zihao{4}\textbf}%
}
% 三级标题格式
\renewcommand\subsubsection{%
\@startsection{subsubsection}{2}{1\ccwd}{0pt}{1pt}%
{\song\zihao{-4}\textbf}%
}
% 四级标题格式, 此命令无效.
\renewcommand\paragraph{%
\@startsection{paragraph}{1}{0mm}{0.5\baselineskip}{0.5\baselineskip}%
{\zihao{-4}\song\textbf}%
}
\makeatother

%%%%%%%% 目录格式
\setcounter{tocdepth}{3}
\renewcommand{\contentsname}{%
\centering\heiti\zihao{-2}目\quad{}录}


%\titlecontents{标题名}[左间距]{标题格式}{标题标志}{无序号标题}
%{指引线与页码}[下间距]
%标题名 设置所需修改的某一层次标题格式的标题名，如chapter、section
%       等层次标题名，或是table和figure图表标题名
%左间距 可选参数，不能省略
%标题格式 设置标题的整体格式，如字体、字体尺寸、与上一个标题的
%         垂直距离等。该参数可空置。
%标题标志 设置标题标志的格式,如序号格式、序号宽度、序号与标题
%         内容之间的间距等。该参数不能空置, 否则标题将无标题标志。
%无序号标题 设置无序号标题的格式, 如字体、字体尺寸等。该参数可以空置
%指引线与页码 设置标题与页码之间的指引线样式以及页码的格式,
%           该参数如果空置, 标题将无指引线和页码。
%下间距 可选参数, 用于设置标题排版后还需要执行的命令, 例如与下个标题的垂直间距等。该参数常被省略。
%
%作者：5john家安
%链接：https://www.jianshu.com/p/ccd14653a128
%来源：简书
%著作权归作者所有。商业转载请联系作者获得授权，非商业转载请注明出处。
% 一级标题
\titlecontents{section}
[0em]
{\zihao{-4} \song}
{\contentslabel{0em}\quad}
{}
{\titlerule*[0.5pc]{$\cdot$}\textrm{\contentspage}}
% 二级标题
\titlecontents{subsection}
[3.0em]
{\zihao{-4}\song}
{\contentslabel{1.5em}\quad\!\!}
{}
{\titlerule*[0.5pc]{$\cdot$}\textrm{\contentspage}}

% 三级标题, 此版本不显示此层次标题
\titlecontents{subsubsection}
[5.5em]
{\zihao{-4}\song}
{\contentslabel{2.5em}\quad\!\!}
{}
{\titlerule*[0.5pc]{$\cdot$}\textrm{\contentspage}}

\renewcommand{\figurename}{\zihao{-5}图}
\renewcommand\tablename{\zihao{-5}表}
\renewcommand\arraystretch{1.5}  %% 设置表格行高

\zihao{-4}
\linespread{1.5}  % 1.5倍行间距
%\baselineskip=23pt
\parskip=0pt      %段间距与行间距相等

\widowpenalty=0
\clubpenalty=0000
\allowdisplaybreaks  %允许多行公式换页
